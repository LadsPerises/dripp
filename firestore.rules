rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null; // Removing emailVerified requirement for test environments sometimes, but keeping strict might break google login if it's not strictly verified out of box, usually Google Login is verified though.
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'ladislaupiedoso@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt', 'name'])
        && data.keys().size() == 4
        && data.email is string
        && data.email.size() <= 200
        && data.name is string
        && data.name.size() <= 200
        && data.role in ['customer', 'admin', 'driver']
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isDriver();
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (incoming().role == 'customer' || isAdmin());
      
      allow update: if isValidId(userId) && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['email', 'name']) && incoming().get('email', '') is string && incoming().get('name', '') is string) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['email', 'role', 'name']) && incoming().get('role', 'customer') in ['customer', 'admin', 'driver'] && incoming().get('name', '') is string)
      );
      
      allow delete: if isAdmin();
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug', 'isActive', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.slug is string && data.slug.size() > 0 && data.slug.size() <= 100 && data.slug.matches('^[a-zA-Z0-9\\-]+$')
        && data.isActive is bool
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /categories/{categoryId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isAdmin() && isValidId(categoryId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'slug', 'isActive', 'updatedAt']) &&
        incoming().name is string && incoming().name.size() > 0 && incoming().name.size() <= 100 &&
        incoming().slug is string && incoming().slug.size() > 0 && incoming().slug.size() <= 100 && incoming().slug.matches('^[a-zA-Z0-9\\-]+$') &&
        incoming().isActive is bool &&
        incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'categoryId', 'images', 'isPublished', 'stock', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.description is string && data.description.size() <= 5000
        && data.price is number && data.price >= 0
        && data.categoryId is string && isValidId(data.categoryId) && exists(/databases/$(database)/documents/categories/$(data.categoryId))
        && data.images is list && data.images.size() <= 10
        && data.isPublished is bool
        && data.stock is number && data.stock >= 0
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /products/{productId} {
      allow list: if resource.data.isPublished == true || isAdmin();
      allow get: if resource.data.isPublished == true || isAdmin();
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidId(productId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'categoryId', 'images', 'isPublished', 'stock', 'updatedAt']) &&
        incoming().name is string && incoming().name.size() > 0 && incoming().name.size() <= 150 &&
        incoming().description is string && incoming().description.size() <= 5000 &&
        incoming().price is number && incoming().price >= 0 &&
        incoming().categoryId is string && isValidId(incoming().categoryId) &&
        (incoming().categoryId == existing().categoryId || exists(/databases/$(database)/documents/categories/$(incoming().categoryId))) &&
        incoming().images is list && incoming().images.size() <= 10 &&
        incoming().isPublished is bool &&
        incoming().stock is number && incoming().stock >= 0 &&
        incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    function isDriver() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver';
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'status', 'items', 'totalAmount', 'createdAt', 'updatedAt', 'deliveryAddress', 'contactNumber']) &&
        data.userId is string && data.userId == request.auth.uid &&
        data.status is string && data.status in ['pending', 'accepted', 'in_transit', 'delivered', 'cancelled'] &&
        data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
        data.totalAmount is number && data.totalAmount >= 0 &&
        data.deliveryAddress is string && data.deliveryAddress.size() <= 400 && data.deliveryAddress.size() > 0 &&
        data.contactNumber is string && data.contactNumber.size() <= 50 && data.contactNumber.size() > 0 &&
        data.createdAt == request.time &&
        data.updatedAt == request.time;
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || isDriver();
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isValidId(orderId) && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'deliveryDate', 'updatedAt']) && incoming().status in ['pending', 'accepted', 'in_transit', 'delivered', 'cancelled'] && incoming().updatedAt == request.time) ||
        (isDriver() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status in ['in_transit', 'delivered'] && incoming().updatedAt == request.time && existing().driverId == request.auth.uid) ||
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'cancelled' && incoming().updatedAt == request.time && existing().status == 'pending')
      );
      allow delete: if false;
    }
  }
}
